{
  "expo": {
    "name": "AI Browser",
    "slug": "ai-browser",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.ishwar.aibrowser",
      "permissions": ["INTERNET"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            { "scheme": "http" },
            { "scheme": "https" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.ishwar.aibrowser"
    }
  }
}
