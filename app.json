{
  "expo": {
    "name": "AI Browser",
    "slug": "ai-browser",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.iswar.aibrowser",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2A1B6B"
      },
      "permissions": [
        "INTERNET",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "http"
            },
            {
              "scheme": "https"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "./plugins/withBackgroundAudio.js",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow AI Browser to use Face ID to unlock the app."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AI Browser to use the camera to scan QR codes."
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.iswar.aibrowser"
    },
    "extra": {
      "eas": {
        "projectId": "b6a492e2-da37-48a8-9ad8-4dd56a025027"
      }
    }
  }
}
